# KnowledgeVault-YT Environment Configuration
# Copy this file to .env and fill in your values

# Neo4j Configuration
# Default password is 'knowledgevault'
NEO4J_PASSWORD=knowledgevault

# Ollama Configuration (if running outside docker)
# OLLAMA_HOST=http://localhost:11434

# Optional: Port settings
# APP_PORT=8501
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
